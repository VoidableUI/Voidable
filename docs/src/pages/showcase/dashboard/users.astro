      // Dialog elements
      const dialog = document.getElementById('user-dialog') as any;

      function getStatusBadge(status: string): string {
        const colorMap: Record<string, string> = {
          active: 'success',
          expired: 'error',
          pending: 'warning',
        };
        const labelMap: Record<string, string> = {
          active: 'Active',
          expired: 'Expired',
          pending: 'Pending',
        };
        return `<void-badge color="${colorMap[status] || 'neutral'}" size="sm">${labelMap[status] || status}</void-badge>`;
      }

      async function openUserDialog(email: string) {
        const user = userData[email];
        if (!user) return;

        dialog.heading = user.name;
        dialog.open = true;
        await dialog.updateComplete;

        const body = dialog.querySelector('.void-dialog-body');
        if (!body) return;

        const mfaBadge = user.auth.mfaEnabled
          ? '<void-badge color="success" size="sm">Enabled</void-badge>'
          : '<void-badge color="error" size="sm">Disabled</void-badge>';

        const apiKeysRows = user.apiKeys
          .map(
            (k) => `
          <tr>
            <td>${k.name}</td>
            <td><span class="key-mono">${k.key}</span></td>
            <td>${k.created}</td>
            <td>${k.lastUsed}</td>
          </tr>`
          )
          .join('');

        const devicesRows = user.devices
          .map(
            (d) => `
          <tr>
            <td>${d.device}</td>
            <td><span class="scopes-cell">${d.scopes.map((s) => `<void-tag size="sm">${s}</void-tag>`).join('')}</span></td>
            <td>${getStatusBadge(d.status)}</td>
            <td>${d.lastUsed}</td>
          </tr>`
          )
          .join('');

        body.innerHTML = `
          <void-tabs value="auth-status">
            <void-tab-panel tab="auth-status" label="Auth Status">
              <div class="auth-status-grid">
                <div class="auth-status-item">
                  <span class="auth-status-label">Last Login</span>
                  <span class="auth-status-value">${user.auth.lastLogin}</span>
                </div>
                <div class="auth-status-item">
                  <span class="auth-status-label">Last IP</span>
                  <span class="auth-status-value mono">${user.auth.lastIP}</span>
                </div>
                <div class="auth-status-item">
                  <span class="auth-status-label">Login Count</span>
                  <span class="auth-status-value">${user.auth.loginCount}</span>
                </div>
                <div class="auth-status-item">
                  <span class="auth-status-label">MFA Status</span>
                  <span class="auth-status-value">${mfaBadge}</span>
                </div>
                <div class="auth-status-item">
                  <span class="auth-status-label">Account Created</span>
                  <span class="auth-status-value">${user.auth.accountCreated}</span>
                </div>
                <div class="auth-status-item">
                  <span class="auth-status-label">Active Sessions</span>
                  <span class="auth-status-value">${user.auth.activeSessions}</span>
                </div>
              </div>
            </void-tab-panel>
            <void-tab-panel tab="tokens" label="Tokens">
              <div class="tokens-section">
                <div class="tokens-section-header">
                  <div class="tokens-section-title">API Keys</div>
                  <void-button variant="outline" size="sm" id="create-key-btn" color="success">Create Key</void-button>
                </div>
                <table class="tokens-table">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Key</th>
                      <th>Created</th>
                      <th>Last Used</th>
                    </tr>
                  </thead>
                  <tbody>${apiKeysRows}</tbody>
                </table>
              </div>
              <div class="tokens-section">
                <div class="tokens-section-title">OAuth Device Authorizations (RFC 8628)</div>
                <table class="tokens-table">
                  <thead>
                    <tr>
                      <th>Device</th>
                      <th>Scopes</th>
                      <th>Status</th>
                      <th>Last Used</th>
                    </tr>
                  </thead>
                  <tbody>${devicesRows}</tbody>
                </table>
              </div>
            </void-tab-panel>
          </void-tabs>
        `;

        // Re-sync tabs after custom elements upgrade from innerHTML insertion
        await new Promise(r => requestAnimationFrame(r));
        const voidTabs = body.querySelector('void-tabs') as any;
        if (voidTabs) {
          voidTabs._panels = Array.from(voidTabs.querySelectorAll('void-tab-panel'));
          voidTabs.value = 'auth-status';
          voidTabs.requestUpdate();
          voidTabs._syncPanels();
        }
      }

      const PAGE_SIZE = 10;
      const allRows = Array.from(document.querySelectorAll('.user-row'));
      const pagination = document.getElementById('users-pagination') as any;

      function showPage(page: number) {
        const start = (page - 1) * PAGE_SIZE;
        allRows.forEach((row, i) => {
          (row as HTMLElement).style.display = i >= start && i < start + PAGE_SIZE ? '' : 'none';
        });
      }

      showPage(1);

      pagination?.addEventListener('void-change', (e: Event) => {
        showPage((e as CustomEvent).detail.value);
      });

      allRows.forEach((row) => {
        row.addEventListener('click', () => {
          const email = (row as HTMLElement).dataset.email;
          if (email) openUserDialog(email);
        });
      });

      // Create Key dialog
      const createKeyDialog = document.getElementById('create-key-dialog') as any;

      function generateMockToken(): string {
        const chars = 'abcdef0123456789';
        let token = 'vk_live_';
        for (let i = 0; i < 48; i++) token += chars[Math.floor(Math.random() * chars.length)];
        return token;
      }

      async function openCreateKeyDialog() {
        createKeyDialog.heading = 'Create API Key';
        createKeyDialog.open = true;
        await createKeyDialog.updateComplete;

        const body = createKeyDialog.querySelector('.void-dialog-body');
        if (!body) return;

        body.innerHTML = `
          <form class="create-key-form" id="create-key-form">
            <div class="create-key-field">
              <label class="create-key-label" for="key-name">Name</label>
              <void-input id="key-name" placeholder="e.g. Production API, CI/CD Token" required></void-input>
            </div>
            <div class="create-key-field">
              <label class="create-key-label">Scopes</label>
              <div class="create-key-scopes">
                <label class="scope-option">
                  <void-checkbox value="read" checked></void-checkbox>
                  <span>read</span>
                </label>
                <label class="scope-option">
                  <void-checkbox value="write"></void-checkbox>
                  <span>write</span>
                </label>
                <label class="scope-option">
                  <void-checkbox value="admin"></void-checkbox>
                  <span>admin</span>
                </label>
              </div>
            </div>
            <div class="create-key-actions">
              <void-button variant="ghost" size="sm" type="button" id="create-key-cancel" color="error">Cancel</void-button>
              <void-button variant="outline" size="sm" type="button" id="create-key-submit" color="success">Create Key</void-button>
            </div>
          </form>
        `;

        const cancelBtn = body.querySelector('#create-key-cancel');
        const submitBtn = body.querySelector('#create-key-submit');

        cancelBtn?.addEventListener('click', () => { createKeyDialog.open = false; });

        submitBtn?.addEventListener('click', async () => {
          const nameInput = body.querySelector('#key-name') as any;
          const name = nameInput?.value?.trim() || 'Untitled Key';
          const token = generateMockToken();

          createKeyDialog.heading = 'API Key Created';
          body.innerHTML = `
            <div class="create-key-success">
              <div class="create-key-success-name">${name}</div>
              <void-banner color="warning">This token will not be displayed again. Copy it now.</void-banner>
              <void-action-input
                id="copy-token-input"
                value="${token}"
                icon="copy"
                action-label="Copy token"
                readonly
                style="font-family: var(--void-font-mono); font-size: var(--void-text-xs);"
              ></void-action-input>
              <div class="create-key-actions">
                <void-button variant="outline" size="sm" id="create-key-done">Done</void-button>
              </div>
            </div>
          `;

          body.querySelector('#copy-token-input')?.addEventListener('void-action', async () => {
            const el = body.querySelector('#copy-token-input') as any;
            await navigator.clipboard.writeText(token);
            el.icon = 'check';
            el.actionLabel = 'Copied!';
            setTimeout(() => { el.icon = 'copy'; el.actionLabel = 'Copy token'; }, 2000);
          });

          body.querySelector('#create-key-done')?.addEventListener('click', () => {
            createKeyDialog.open = false;
          });
        });
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('#create-key-btn');
        if (btn) openCreateKeyDialog();
      });
    </script>

    <!-- Global styles for dynamically injected dialog content + popover overrides -->
    <style is:global>
      .toolbar-row void-popover[position="bottom"] .void-popover-body {
        left: auto !important;
        right: 0;
      }

      /* ── Dialog: Auth status grid ── */
      .void-dialog-body .auth-status-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--void-space-4);
        padding: var(--void-space-4) 0;
      }

      .void-dialog-body .auth-status-item {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-1);
      }

      .void-dialog-body .auth-status-label {
        font-size: var(--void-text-2xs);
        font-family: var(--void-font-mono);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-muted);
      }

      .void-dialog-body .auth-status-value {
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-medium);
        color: var(--void-color-text);
      }

      /* ── Dialog: Tokens sections ── */
      .void-dialog-body .tokens-section {
        margin-bottom: var(--void-space-5);
      }

      .void-dialog-body .tokens-section:last-child {
        margin-bottom: 0;
      }

      .void-dialog-body .tokens-section-title {
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-semibold);
        color: var(--void-color-text);
        margin-bottom: var(--void-space-3);
        letter-spacing: var(--void-tracking-snug);
      }

      .void-dialog-body .tokens-table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--void-text-xs);
      }

      .void-dialog-body .tokens-table th {
        text-align: left;
        padding: var(--void-space-2) var(--void-space-3);
        font-size: var(--void-text-2xs);
        font-family: var(--void-font-mono);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-muted);
        border-bottom: 1px solid var(--void-color-border);
        font-weight: var(--void-weight-medium);
      }

      .void-dialog-body .tokens-table td {
        padding: var(--void-space-2) var(--void-space-3);
        border-bottom: 1px solid var(--void-color-border);
        color: var(--void-color-text-secondary);
      }

      .void-dialog-body .tokens-table tr:last-child td {
        border-bottom: none;
      }

      .void-dialog-body .key-mono {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
        color: var(--void-color-text);
      }

      .void-dialog-body .scopes-cell {
        display: flex;
        gap: var(--void-space-1);
        flex-wrap: wrap;
      }

      /* ── Dialog: Tokens section header ── */
      .void-dialog-body .tokens-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: var(--void-space-3);
      }

      .void-dialog-body .tokens-section-header .tokens-section-title {
        margin-bottom: 0;
      }

      /* ── Create Key dialog ── */
      .create-key-form {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-4);
        padding: var(--void-space-2) 0 0;
      }

      .create-key-field {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-2);
      }

      .create-key-label {
        font-size: var(--void-text-2xs);
        font-family: var(--void-font-mono);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-muted);
      }

      .create-key-scopes {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-2);
      }

      .scope-option {
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
        font-size: var(--void-text-sm);
        color: var(--void-color-text);
        cursor: pointer;
      }

      .create-key-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: var(--void-space-2);
        padding-top: var(--void-space-5);
        border-top: 1px solid var(--void-color-border);
      }

      .create-key-success {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-4);
        padding: var(--void-space-2) 0 0;
        min-width: 0;
        overflow: hidden;
      }

      .create-key-success-name {
        font-size: var(--void-text-base);
        font-weight: var(--void-weight-semibold);
        color: var(--void-color-text);
      }

      .create-key-success void-action-input {
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
      }

      @media (max-width: 1024px) {
        .void-dialog-body .auth-status-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 768px) {
        .void-dialog-body .auth-status-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
