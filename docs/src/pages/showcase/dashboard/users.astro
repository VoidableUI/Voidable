---
import '@voidable/theme';
import iconLayoutDashboard from '@tabler/icons/outline/layout-dashboard.svg?raw';
import iconChartBar from '@tabler/icons/outline/chart-bar.svg?raw';
import iconUsers from '@tabler/icons/outline/users.svg?raw';
import iconList from '@tabler/icons/outline/list.svg?raw';
import iconCreditCard from '@tabler/icons/outline/credit-card.svg?raw';
import iconSettings from '@tabler/icons/outline/settings.svg?raw';
import iconChevronDown from '@tabler/icons/outline/chevron-down.svg?raw';
import iconBell from '@tabler/icons/outline/bell.svg?raw';
import iconSun from '@tabler/icons/outline/sun.svg?raw';
import iconMoon from '@tabler/icons/outline/moon.svg?raw';
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Users — Dashboard Showcase — Voidable</title>
    <meta name="description" content="Users listing page for the Voidable dashboard showcase." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: var(--void-font-sans);
        color: var(--void-color-text);
        background: var(--void-color-bg);
      }

      body {
        min-height: 100dvh;
        line-height: var(--void-leading-normal);
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Site nav ── */
      .site-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: color-mix(in srgb, var(--void-color-bg) 88%, transparent);
        backdrop-filter: saturate(140%) blur(6px); /* token-ok: backdrop blur */
        -webkit-backdrop-filter: saturate(140%) blur(6px); /* token-ok: backdrop blur */
        border-bottom: 1px solid var(--void-color-border);
        flex-shrink: 0;
      }

      .site-nav-inner {
        max-width: 100%;
        padding: 0 var(--void-space-6);
        display: flex;
        align-items: center;
        gap: var(--void-space-6);
        height: var(--void-space-12);
      }

      .site-wordmark {
        font-family: var(--void-font-mono);
        font-weight: var(--void-weight-bold);
        font-size: var(--void-text-base);
        letter-spacing: var(--void-tracking-tightest);
        color: var(--void-color-text);
      }

      .site-nav-links {
        display: flex;
        gap: var(--void-space-1);
        list-style: none;
      }

      .site-nav-links a {
        display: block;
        padding: var(--void-space-1) var(--void-space-2);
        font-size: var(--void-text-xs);
        color: var(--void-color-text-secondary);
        border-radius: var(--void-radius-sm);
        transition: color var(--void-duration-fast);
      }

      .site-nav-links a:hover,
      .site-nav-links a.active {
        color: var(--void-color-text);
      }

      .site-nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: var(--void-space-3);
      }

      .theme-icon {
        display: flex;
        width: var(--void-space-4);
        height: var(--void-space-4);
      }
      .theme-icon :global(svg) {
        width: 100%;
        height: 100%;
      }
      [data-theme="dark"] .theme-icon-sun { display: flex; }
      [data-theme="dark"] .theme-icon-moon { display: none; }
      [data-theme="light"] .theme-icon-sun { display: none; }
      [data-theme="light"] .theme-icon-moon { display: flex; }

      /* ── App shell ── */
      .app-shell {
        display: flex;
        flex: 1;
        min-height: calc(100dvh - var(--void-space-12));
      }

      /* ── Sidebar column ── */
      .sidebar-column {
        flex-shrink: 0;
        border-right: 1px solid var(--void-color-border);
        background: var(--void-color-bg);
      }

      void-sidebar {
        position: sticky;
        top: var(--void-space-12);
        height: calc(100dvh - var(--void-space-12)) !important;
        background: var(--void-color-bg) !important;
        border-right: none !important;
      }

      .sidebar-header {
        padding: 0 var(--void-space-4);
        border-bottom: 1px solid var(--void-color-border);
        display: flex;
        align-items: center;
        flex-shrink: 0;
        min-height: 4.875rem; /* token-ok: matches sidebar internal layout */
        box-sizing: border-box;
        background: var(--void-color-bg-secondary);
      }

      .sidebar-project {
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
        padding: var(--void-space-2) var(--void-space-2);
        border-radius: var(--void-radius-md);
        cursor: pointer;
        transition: background var(--void-duration-fast);
      }

      .sidebar-project:hover {
        background: var(--void-color-bg-hover);
      }

      .sidebar-project-icon {
        width: var(--void-space-6);
        height: var(--void-space-6);
        border-radius: var(--void-radius-sm);
        background: var(--void-color-bg-accent);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: var(--void-text-2xs);
        font-family: var(--void-font-mono);
        font-weight: var(--void-weight-bold);
        color: var(--void-color-text);
      }

      .sidebar-project-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }

      .sidebar-project-name {
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-semibold);
        color: var(--void-color-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sidebar-project-env {
        font-size: var(--void-text-xs);
        color: var(--void-color-text-secondary);
        font-family: var(--void-font-mono);
        white-space: nowrap;
      }

      .sidebar-chevron {
        width: var(--void-space-3);
        height: var(--void-space-3);
        display: inline-flex;
        margin-left: auto;
        flex-shrink: 0;
        color: var(--void-color-text-muted);
      }
      .sidebar-chevron :global(svg) {
        width: 100%;
        height: 100%;
      }

      .sidebar-header void-dropdown-menu {
        width: 100%;
      }

      .sidebar-header .sidebar-project {
        width: 100%;
      }

      .project-dropdown-sep {
        margin: var(--void-space-1) var(--void-space-3);
        border: none;
        border-top: 1px solid var(--void-color-border);
      }

      .project-item-active {
        color: var(--void-color-text);
        font-weight: var(--void-weight-semibold);
      }

      .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        padding: var(--void-space-3) var(--void-space-3);
        display: flex;
        flex-direction: column;
        gap: var(--void-space-1);
      }

      .sidebar-section-label {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-2xs);
        font-weight: var(--void-weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-muted);
        padding: var(--void-space-2) var(--void-space-2) var(--void-space-1);
        margin-top: var(--void-space-1);
      }

      .sidebar-nav-item {
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
        padding: var(--void-space-2) var(--void-space-2);
        border-radius: var(--void-radius-md);
        font-size: var(--void-text-sm);
        color: var(--void-color-text-secondary);
        cursor: pointer;
        transition: background var(--void-duration-fast), color var(--void-duration-fast);
        user-select: none;
      }

      .sidebar-nav-item:hover {
        background: var(--void-color-bg-hover);
        color: var(--void-color-text);
      }

      .sidebar-nav-item.active {
        background: var(--void-color-border-strong);
        color: var(--void-color-text);
      }

      .sidebar-nav-icon {
        width: var(--void-space-4);
        height: var(--void-space-4);
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
        opacity: 0.6;
      }
      .sidebar-nav-icon :global(svg) {
        width: 100%;
        height: 100%;
      }

      .active .sidebar-nav-icon {
        opacity: 1;
      }

      .sidebar-nav-item void-badge {
        margin-left: auto;
      }

      .sidebar-footer {
        padding: var(--void-space-3);
        border-top: 1px solid var(--void-color-border);
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
        background: var(--void-color-bg-secondary);
      }

      .sidebar-user-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
        overflow: hidden;
      }

      .sidebar-user-name {
        font-size: var(--void-text-xs);
        font-weight: var(--void-weight-medium);
        color: var(--void-color-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .sidebar-user-role {
        font-size: var(--void-text-2xs);
        color: var(--void-color-text-muted);
      }

      /* ── Main content ── */
      .main-content {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
      }

      /* ── Dashboard header ── */
      .dash-header {
        padding: var(--void-space-5) var(--void-space-6);
        border-bottom: 1px solid var(--void-color-border);
        display: flex;
        align-items: center;
        gap: var(--void-space-4);
        flex-wrap: wrap;
        background: color-mix(in srgb, var(--void-color-bg) 40%, transparent);
        backdrop-filter: blur(4px); /* token-ok: backdrop blur */
        position: sticky;
        top: 0;
        z-index: 10;
        flex-shrink: 0;
      }

      .dash-title-group {
        display: flex;
        flex-direction: column;
        gap: var(--void-space-1);
      }

      .dash-breadcrumb {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-2xs);
        color: var(--void-color-text-muted);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
      }

      .dash-title {
        font-size: var(--void-text-md);
        font-weight: var(--void-weight-semibold);
        letter-spacing: var(--void-tracking-tight);
        color: var(--void-color-text);
        line-height: var(--void-leading-tight);
      }

      .dash-header-controls {
        margin-left: auto;
        display: flex;
        align-items: stretch;
        gap: var(--void-space-3);
        flex-wrap: wrap;
      }

      /* ── Content layout ── */
      .content-area {
        flex: 1;
        padding: var(--void-space-6);
        display: flex;
        flex-direction: column;
        gap: var(--void-space-5);
      }

      /* ── Table section ── */
      .table-section {
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-lg);
        overflow: hidden;
      }

      .table-section-header {
        padding: var(--void-space-3) var(--void-space-5);
        border-bottom: 1px solid var(--void-color-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--void-color-bg-secondary);
      }

      .table-section-title {
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-medium);
        color: var(--void-color-text);
        letter-spacing: var(--void-tracking-snug);
      }

      .table-section-count {
        font-size: var(--void-text-xs);
        color: var(--void-color-text-muted);
        font-family: var(--void-font-mono);
      }

      .table-section void-pagination {
        display: flex;
        justify-content: center;
        padding: var(--void-space-3) var(--void-space-5);
        border-top: 1px solid var(--void-color-border);
      }

      .cell-with-dot {
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
      }

      /* ── Mono text ── */
      .mono {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
      }

      .text-secondary {
        color: var(--void-color-text-secondary);
      }

      .text-sm {
        font-size: var(--void-text-xs);
      }

      /* ── Inline icons (set:html wrappers) ── */
      .icon-inline {
        display: inline-flex;
        align-items: center;
        flex-shrink: 0;
      }
      .icon-inline :global(svg) {
        width: 14px; /* token-ok: icon size */
        height: 14px; /* token-ok: icon size */
        margin-right: var(--void-space-1);
      }
      .icon-chevron :global(svg) {
        width: 10px; /* token-ok: chevron icon size */
        height: 10px; /* token-ok: chevron icon size */
        margin-right: 0;
        margin-left: var(--void-space-1);
        opacity: 0.5;
      }

      /* ── Mobile hamburger (hidden on desktop) ── */
      .mobile-hamburger {
        display: none;
      }

      /* ── Sidebar backdrop (hidden by default) ── */
      .sidebar-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: var(--void-color-bg-overlay);
        z-index: calc(var(--void-z-modal) - 1);
      }

      .sidebar-open .sidebar-backdrop {
        display: block;
      }

      /* ── User cell (avatar + name) ── */
      .user-cell {
        display: flex;
        align-items: center;
        gap: var(--void-space-2);
      }

      .user-cell span {
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-medium);
        color: var(--void-color-text);
      }

      /* ── Clickable rows ── */
      .user-row {
        cursor: pointer;
        transition: background var(--void-duration-fast);
      }

      .user-row:hover {
        background: var(--void-color-bg-hover);
      }


      /* ── Responsive: Tablet (<=1024px) ── */
      @media (max-width: 1024px) {
      }

      /* ── Responsive: Mobile (<=768px) ── */
      @media (max-width: 768px) {
        /* Sidebar: hidden by default, overlay when open */
        .sidebar-column {
          display: none;
          position: fixed;
          top: 0;
          left: 0;
          bottom: 0;
          z-index: var(--void-z-modal);
          width: 220px; /* token-ok: matches sidebar width prop */
          border-right: 1px solid var(--void-color-border);
          background: var(--void-color-bg);
        }

        .sidebar-open .sidebar-column {
          display: block;
        }

        .sidebar-open void-sidebar {
          position: static !important;
          height: 100% !important;
        }

        /* Show hamburger */
        .mobile-hamburger {
          display: inline-flex;
        }

        /* Hide site nav links (sidebar has navigation) */
        .site-nav-links {
          display: none;
        }

        /* Dash header: stack vertically */
        .dash-header {
          flex-direction: column;
          align-items: flex-start;
          padding-left: var(--void-space-3);
          padding-right: var(--void-space-3);
        }

        .dash-header-controls {
          margin-left: 0;
          width: 100%;
        }

        /* Reduce horizontal padding */
        .content-area {
          padding-left: var(--void-space-3);
          padding-right: var(--void-space-3);
        }

        .site-nav-inner {
          padding-left: var(--void-space-3);
          padding-right: var(--void-space-3);
        }

        /* Table horizontal scroll */
        .table-section {
          overflow-x: auto;
        }

      }
    </style>
  </head>

  <body>

    <!-- Site nav -->
    <nav class="site-nav">
      <div class="site-nav-inner">
        <a href="/" class="site-wordmark">voidable</a>
        <void-hamburger id="sidebar-toggle" class="mobile-hamburger" size="md"></void-hamburger>
        <ul class="site-nav-links">
          <li><a href="/getting-started/introduction/">Docs</a></li>
          <li><a href="/components/overview/">Components</a></li>
          <li><a href="/showcase/dashboard/" class="active">Showcase</a></li>
        </ul>
        <div class="site-nav-right">
          <void-button id="theme-toggle" variant="outline" size="md" aria-label="Toggle theme">
            <span class="theme-icon theme-icon-sun" set:html={iconSun} />
            <span class="theme-icon theme-icon-moon" set:html={iconMoon} />
          </void-button>
          <void-button variant="outline" size="md">
            <a href="https://github.com/VoidableUI/Voidable" target="_blank">GitHub</a>
          </void-button>
        </div>
      </div>
    </nav>

    <!-- App shell -->
    <div class="app-shell">

      <!-- Sidebar -->
      <div class="sidebar-column">
      <void-sidebar width="220px" collapsed-width="52px">
        <div class="sidebar-header">
          <void-dropdown-menu position="bottom-start" style="width: 100%;">
            <div class="sidebar-project">
              <div class="sidebar-project-icon">V</div>
              <div class="sidebar-project-info">
                <span class="sidebar-project-name">Voidable Cloud</span>
                <span class="sidebar-project-env">production</span>
              </div>
              <span class="sidebar-chevron" set:html={iconChevronDown} />
            </div>
            <void-dropdown-menu-item class="project-item-active">&#x2713;&ensp;Voidable Cloud</void-dropdown-menu-item>
            <void-dropdown-menu-item>Voidable Staging</void-dropdown-menu-item>
            <void-dropdown-menu-item>Personal Sandbox</void-dropdown-menu-item>
            <hr class="project-dropdown-sep">
            <void-dropdown-menu-item>Create New Project</void-dropdown-menu-item>
          </void-dropdown-menu>
        </div>

        <nav class="sidebar-nav">
          <span class="sidebar-section-label">Main</span>

          <a href="/showcase/dashboard/" class="sidebar-nav-item">
            <span class="sidebar-nav-icon" set:html={iconLayoutDashboard} />
            <span>Overview</span>
          </a>

          <div class="sidebar-nav-item">
            <span class="sidebar-nav-icon" set:html={iconChartBar} />
            <span>Analytics</span>
            <void-badge size="sm">New</void-badge>
          </div>

          <a href="/showcase/dashboard/users/" class="sidebar-nav-item active">
            <span class="sidebar-nav-icon" set:html={iconUsers} />
            <span>Users</span>
          </a>

          <div class="sidebar-nav-item">
            <span class="sidebar-nav-icon" set:html={iconList} />
            <span>Logs</span>
          </div>

          <span class="sidebar-section-label">Account</span>

          <div class="sidebar-nav-item">
            <span class="sidebar-nav-icon" set:html={iconCreditCard} />
            <span>Billing</span>
          </div>

          <div class="sidebar-nav-item">
            <span class="sidebar-nav-icon" set:html={iconSettings} />
            <span>Settings</span>
          </div>
        </nav>

        <div class="sidebar-footer">
          <void-avatar initials="KW" size="sm"></void-avatar>
          <div class="sidebar-user-info">
            <span class="sidebar-user-name">Kaz Walker</span>
            <span class="sidebar-user-role">Admin</span>
          </div>
        </div>
      </void-sidebar>
      </div>

      <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

      <!-- Main content area -->
      <div class="main-content">

        <!-- Dashboard header -->
        <header class="dash-header">
          <div class="dash-title-group">
            <span class="dash-breadcrumb">Showcase / Dashboard / Users</span>
            <h1 class="dash-title">Users</h1>
          </div>

          <div class="dash-header-controls">
            <void-action-input placeholder="Search users..." icon="search" action-label="User Search" style="min-width: 200px;"></void-action-input>
            <void-button variant="outline" color="success">Add User</void-button>
          </div>
        </header>

        <!-- Main content -->
        <div class="content-area">

          <!-- Users table -->
          <div class="table-section">
            <div class="table-section-header">
              <span class="table-section-title">All Users</span>
              <span class="table-section-count">13 users</span>
            </div>

            <void-table>
              <table>
                <thead>
                  <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Last Login</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="user-row" data-email="james@example.com">
                    <td><span class="user-cell"><void-avatar initials="JW" size="sm"></void-avatar><span>James Walker</span></span></td>
                    <td class="mono">james@example.com</td>
                    <td><void-badge variant="filled" color="accent">Admin</void-badge></td>
                    <td><span class="cell-with-dot"><void-status-dot status="online"></void-status-dot>Online</span></td>
                    <td class="text-sm text-secondary">2 min ago</td>
                  </tr>
                  <tr class="user-row" data-email="sarah@example.com">
                    <td><span class="user-cell"><void-avatar initials="SM" size="sm"></void-avatar><span>Sarah Mitchell</span></span></td>
                    <td class="mono">sarah@example.com</td>
                    <td><void-badge variant="filled">Editor</void-badge></td>
                    <td><span class="cell-with-dot"><void-status-dot status="online"></void-status-dot>Online</span></td>
                    <td class="text-sm text-secondary">12 min ago</td>
                  </tr>
                  <tr class="user-row" data-email="tom@example.com">
                    <td><span class="user-cell"><void-avatar initials="TA" size="sm"></void-avatar><span>Tom Anderson</span></span></td>
                    <td class="mono">tom@example.com</td>
                    <td><void-badge variant="outline">Viewer</void-badge></td>
                    <td><span class="cell-with-dot"><void-status-dot status="away"></void-status-dot>Away</span></td>
                    <td class="text-sm text-secondary">1 hour ago</td>
                  </tr>
                  <tr class="user-row" data-email="emily@example.com">
                    <td><span class="user-cell"><void-avatar initials="EP" size="sm"></void-avatar><span>Emily Parker</span></span></td>
                    <td class="mono">emily@example.com</td>
                    <td><void-badge variant="filled" color="accent">Admin</void-badge></td>
                    <td><span class="cell-with-dot"><void-status-dot status="online"></void-status-dot>Online</span></td>
                    <td class="text-sm text-secondary">5 min ago</td>
                  </tr>
                  <tr class="user-row" data-email="mike@example.com">
                    <td><span class="user-cell"><void-avatar initials="MT" size="sm"></void-avatar><span>Mike Thompson</span></span></td>
                    <td class="mono">mike@example.com</td>
