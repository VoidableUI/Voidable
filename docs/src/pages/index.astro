---
import '@voidable/theme';
import iconBrandGithub from '@tabler/icons/outline/brand-github.svg?raw';
import iconSun from '@tabler/icons/outline/sun.svg?raw';
import iconMoon from '@tabler/icons/outline/moon.svg?raw';
import { codeToHtml } from 'shiki';

const cssCode = `/* Override one variable.
   Watch the entire library remap. */

:root {
  --void-color-accent: #3b82f6;
  --void-color-accent-hover: #2563eb;
  --void-radius-md: 8px;

  --void-color-bg: #0a0e1a;
  --void-color-text: #e5e7eb;
}

[data-shape="sharp"] {
  --void-radius-md: 0;
  --void-radius-lg: 0;
}`;

const highlightedCss = await codeToHtml(cssCode, {
  lang: 'css',
  theme: 'github-dark-default',
});

const version = import.meta.env.VOIDABLE_VERSION || 'v0.0.0';
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Voidable. Devoid of style.</title>
    <meta name="description" content="A framework-agnostic web component library built with Lit 3. Light DOM, CSS token theming, 10 adapters for React, Vue, Solid, Svelte, Angular, Hotwire, Alpine, LiveView, Qwik, and Astro." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-family: var(--void-font-sans);
        color: var(--void-color-text);
        background: var(--void-color-bg);
      }

      body {
        min-height: 100dvh;
        line-height: var(--void-leading-normal);
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 var(--void-space-10);
      }

      /* ── Nav ── */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--void-color-bg) 86%, transparent);
        backdrop-filter: saturate(140%) blur(6px);
        -webkit-backdrop-filter: saturate(140%) blur(6px);
        border-bottom: 1px solid var(--void-color-border);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        gap: var(--void-space-7);
        padding: var(--void-space-4) 0;
      }

      .nav-wordmark {
        font-family: var(--void-font-mono);
        font-weight: var(--void-weight-bold);
        font-size: var(--void-text-md);
        letter-spacing: var(--void-tracking-tightest);
        color: var(--void-color-text);
      }

      .nav-links {
        display: flex;
        gap: var(--void-space-1);
        list-style: none;
      }

      .nav-links a {
        display: block;
        padding: var(--void-space-1h) var(--void-space-3);
        font-size: var(--void-text-sm);
        font-weight: var(--void-weight-normal);
        color: var(--void-color-text-secondary);
        border-radius: var(--void-radius-sm);
        transition: color 150ms;
      }

      .nav-links a:hover {
        color: var(--void-color-text);
      }

      .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: var(--void-space-3);
      }

      .nav-right void-button {
        --tone-subtle: transparent;
      }

      .nav-github {
        display: inline-flex;
        align-items: center;
        gap: var(--void-space-1h);
        color: inherit;
        text-decoration: none;
      }

      .nav-github-icon {
        display: flex;
        width: 14px;
        height: 14px;
      }
      .nav-github-icon :global(svg) {
        width: 100%;
        height: 100%;
      }

      .theme-icon {
        display: flex;
        width: var(--void-space-4);
        height: var(--void-space-4);
      }
      .theme-icon :global(svg) {
        width: 100%;
        height: 100%;
      }
      [data-theme="dark"] .theme-icon-sun { display: flex; }
      [data-theme="dark"] .theme-icon-moon { display: none; }
      [data-theme="light"] .theme-icon-sun { display: none; }
      [data-theme="light"] .theme-icon-moon { display: flex; }

      @media (max-width: 720px) {
        .nav-links {
          display: none;
        }
      }

      /* ── Hero ── */
      .hero {
        position: relative;
        padding: var(--void-space-40) var(--void-space-10) var(--void-space-30);
        text-align: center;
        overflow: hidden;
      }

      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 64px 64px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 75%);
        pointer-events: none;
      }

      .hero-glow {
        position: absolute;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        width: 1100px;
        height: 600px;
        background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.10) 0%, transparent 60%);
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        max-width: 80rem;
        margin: 0 auto;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--void-space-2h);
        padding: 0.3125rem var(--void-space-4) 0.3125rem var(--void-space-1h);
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-full);
        font-size: var(--void-text-xs);
        color: var(--void-color-text-secondary);
        margin-bottom: var(--void-space-10);
        background: var(--void-color-bg-secondary);
      }

      .hero-badge-version {
        padding: 0.0625rem var(--void-space-2);
        background: var(--void-color-border);
        border-radius: var(--void-radius-full);
        font-family: var(--void-font-mono);
        font-size: var(--void-text-2xs);
        color: var(--void-color-text);
      }

      .hero h1 {
        font-family: var(--void-font-sans);
        font-weight: var(--void-weight-bold);
        font-size: clamp(3.5rem, 11vw, 10.5rem);
        letter-spacing: var(--void-tracking-tightest);
        line-height: var(--void-leading-display);
        color: var(--void-color-text);
        margin-bottom: var(--void-space-9);
      }

      .hero-sub {
        font-size: var(--void-text-xl);
        color: var(--void-color-text-secondary);
        line-height: var(--void-leading-normal);
        max-width: 38.75rem;
        margin: 0 auto var(--void-space-12);
      }

      .install-pill {
        display: inline-flex;
        align-items: center;
        gap: var(--void-space-2);
        padding: var(--void-space-3) var(--void-space-4);
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-md);
        font-family: var(--void-font-mono);
        font-size: var(--void-text-sm);
        color: var(--void-color-text-secondary);
        margin-bottom: var(--void-space-8);
        background: transparent;
        cursor: pointer;
        transition: color 150ms, border-color 150ms;
      }

      .install-pill:hover {
        color: var(--void-color-text);
        border-color: var(--void-color-border-strong);
      }

      .install-pill-dollar {
        color: var(--void-color-text-muted);
      }

      .hero-actions {
        display: flex;
        gap: var(--void-space-3);
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
      }

      .hero-actions a {
        display: block;
      }

      .hero-actions a {
        color: inherit;
        text-decoration: none;
      }

      .hero-outline-btn {
        --tone-subtle: transparent;
      }
      .hero-outline-btn a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Frameworks / Marquee ── */
      .frameworks {
        padding: var(--void-space-15) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
        border-bottom: 1px solid var(--void-color-border);
      }

      .frameworks-eyebrow {
        text-align: center;
        color: var(--void-color-text-muted);
        margin-bottom: var(--void-space-7);
        font-size: var(--void-text-xs);
        font-family: var(--void-font-mono);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
      }

      .framework-list {
        display: flex;
        gap: var(--void-space-3);
        justify-content: center;
        flex-wrap: wrap;
        max-width: 68.75rem;
        margin: 0 auto;
      }

      .framework-pill {
        padding: var(--void-space-2) var(--void-space-4);
        font-size: var(--void-text-base);
        font-weight: var(--void-weight-medium);
        color: var(--void-color-text-secondary);
        font-family: var(--void-font-mono);
        letter-spacing: var(--void-tracking-snug);
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-full);
        transition: color 150ms, border-color 150ms;
      }

      a.framework-pill:hover {
        color: var(--void-color-text);
        border-color: var(--void-color-border-strong);
      }

      /* ── Feature Grid ── */
      .feature-section {
        padding: var(--void-space-30) var(--void-space-10);
        max-width: 80rem;
        margin: 0 auto;
      }

      .feature-header {
        max-width: 45rem;
        margin-bottom: var(--void-space-16);
      }

      .eyebrow {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
        font-weight: var(--void-weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-secondary);
        margin-bottom: var(--void-space-4);
      }

      .feature-heading {
        font-size: clamp(2.25rem, 5vw, 3.5rem);
        font-weight: var(--void-weight-bold);
        letter-spacing: var(--void-tracking-tight);
        line-height: var(--void-leading-snug);
        color: var(--void-color-text);
      }

      .feature-sub {
        font-size: var(--void-text-md);
        color: var(--void-color-text-secondary);
        line-height: var(--void-leading-normal);
        margin-top: var(--void-space-5);
        max-width: 35rem;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--void-color-border);
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-xl);
        overflow: hidden;
      }

      .feature-card {
        background: var(--void-color-bg);
        padding: var(--void-space-9) var(--void-space-8);
      }

      .feature-card-title {
        font-weight: var(--void-weight-semibold);
        font-size: var(--void-text-md);
        color: var(--void-color-text);
        margin-bottom: var(--void-space-2);
        letter-spacing: var(--void-tracking-snug);
      }

      .feature-card-desc {
        font-size: var(--void-text-base);
        color: var(--void-color-text-secondary);
        line-height: var(--void-leading-normal);
      }

      @media (max-width: 900px) {
        .feature-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 560px) {
        .feature-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ── Token Showcase ── */
      .token-section {
        padding: var(--void-space-30) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
      }

      .token-grid {
        max-width: 80rem;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--void-space-20);
        align-items: center;
      }

      .token-heading {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: var(--void-weight-bold);
        letter-spacing: var(--void-tracking-tight);
        line-height: var(--void-leading-snug);
        margin-bottom: var(--void-space-6);
        color: var(--void-color-text);
      }

      .token-description {
        font-size: var(--void-text-md);
        color: var(--void-color-text-secondary);
        line-height: var(--void-leading-normal);
        margin-bottom: var(--void-space-6);
      }

      .token-description code {
        font-family: var(--void-font-mono);
        font-size: 0.85em;
        padding: 0.05em 0.35em;
        background: var(--void-color-bg-secondary);
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-xs);
      }

      .token-row {
        display: flex;
        align-items: center;
        gap: var(--void-space-3);
        padding: var(--void-space-2) 0;
        border-bottom: 1px solid var(--void-color-border);
      }

      .token-swatch {
        width: 14px;
        height: 14px;
        border-radius: var(--void-radius-xs);
        border: 1px solid var(--void-color-border);
        flex-shrink: 0;
      }

      .token-name {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
        color: var(--void-color-text);
      }

      .token-value {
        margin-left: auto;
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
        color: var(--void-color-text-muted);
      }

      .token-code-block {
        margin: 0;
        overflow: auto;
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-lg);
      }
      .token-code-block :global(pre) {
        margin: 0;
        padding: var(--void-space-8);
        background: var(--void-color-bg-secondary) !important;
        font-family: var(--void-font-mono);
        font-size: var(--void-text-xs);
        line-height: var(--void-leading-loose);
        white-space: pre;
        overflow: auto;
      }
      .token-code-block :global(code) {
        font-family: inherit;
        font-size: inherit;
        line-height: inherit;
      }

      @media (max-width: 720px) {
        .token-grid {
          grid-template-columns: 1fr;
          gap: var(--void-space-12);
        }
      }

      /* ── Live Components ── */
      .components {
        padding: var(--void-space-30) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
      }

      .components-inner {
        max-width: 80rem;
        margin: 0 auto;
      }

      .components-panel {
        border: 1px solid var(--void-color-border);
        border-radius: var(--void-radius-lg);
        padding: var(--void-space-10);
        display: flex;
        flex-direction: column;
        gap: var(--void-space-10);
      }

      .component-row-label {
        font-family: var(--void-font-mono);
        font-size: var(--void-text-2xs);
        font-weight: var(--void-weight-medium);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-widest);
        color: var(--void-color-text-secondary);
        margin-bottom: var(--void-space-3);
      }

      .component-row {
        display: flex;
        flex-wrap: wrap;
        gap: var(--void-space-2);
        align-items: center;
      }
      .component-row + .component-row {
        margin-top: var(--void-space-2);
      }

      /* ── Stats ── */
      .stats {
        padding: var(--void-space-24) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
      }

      .stats-grid {
        max-width: 80rem;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--void-color-border);
        border: 1px solid var(--void-color-border);
      }

      .stat-card {
        background: var(--void-color-bg);
        padding: var(--void-space-10) var(--void-space-7);
        text-align: left;
      }

      .stat-number {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: var(--void-weight-bold);
        letter-spacing: var(--void-tracking-tighter);
        line-height: var(--void-leading-none);
        font-family: var(--void-font-mono);
        color: var(--void-color-text);
        white-space: nowrap;
      }

      .stat-label {
        margin-top: var(--void-space-3);
        font-size: var(--void-text-xs);
        color: var(--void-color-text-muted);
        text-transform: uppercase;
        letter-spacing: var(--void-tracking-wider);
      }

      @media (max-width: 720px) {
        .stats-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 400px) {
        .stats-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ── CTA ── */
      .cta {
        padding: var(--void-space-35) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
        text-align: center;
      }

      .cta h2 {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: var(--void-weight-bold);
        letter-spacing: var(--void-tracking-tighter);
        line-height: var(--void-leading-none);
        color: var(--void-color-text);
        margin-bottom: var(--void-space-7);
      }

      .cta p {
        font-size: var(--void-text-md);
        color: var(--void-color-text-secondary);
        line-height: var(--void-leading-normal);
        max-width: 30rem;
        margin: 0 auto var(--void-space-10);
      }

      .cta-actions {
        display: flex;
        gap: var(--void-space-2h);
        justify-content: center;
        flex-wrap: wrap;
      }
      .cta-actions a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Footer ── */
      .footer {
        padding: var(--void-space-16) var(--void-space-10) var(--void-space-10);
        border-top: 1px solid var(--void-color-border);
      }

      .footer-inner {
        max-width: 80rem;
        margin: 0 auto;
      }

      .footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--void-space-4);
        margin-bottom: var(--void-space-8);
      }

      .footer-wordmark {
        font-family: var(--void-font-mono);
        font-weight: var(--void-weight-bold);
        font-size: var(--void-text-md);
        letter-spacing: var(--void-tracking-tightest);
        color: var(--void-color-text);
      }

      .footer-links {
        display: flex;
        gap: var(--void-space-7);
        list-style: none;
      }

      .footer-links a {
        font-size: var(--void-text-sm);
        color: var(--void-color-text-secondary);
        transition: color 150ms;
      }

      .footer-links a:hover {
        color: var(--void-color-text);
      }

      .footer-bottom {
        padding-top: var(--void-space-6);
        border-top: 1px solid var(--void-color-border);
        display: flex;
        justify-content: space-between;
        font-size: var(--void-text-xs);
        color: var(--void-color-text-muted);
        font-family: var(--void-font-mono);
      }
    </style>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav">
      <div class="container">
        <div class="nav-inner">
          <span class="nav-wordmark">voidable</span>
          <ul class="nav-links">
            <li><a href="/getting-started/introduction/">Docs</a></li>
            <li><a href="/storybook/">Components</a></li>
            <li><a href="/frameworks/react/">Frameworks</a></li>
            <li><a href="/showcase/dashboard">Showcase</a></li>
          </ul>
          <div class="nav-right">
            <void-button id="theme-toggle" variant="outline" size="md" aria-label="Toggle theme">
              <span class="theme-icon theme-icon-sun" set:html={iconSun} />
              <span class="theme-icon theme-icon-moon" set:html={iconMoon} />
            </void-button>
            <void-button variant="outline" size="md">
              <a href="https://github.com/VoidableUI/Voidable" target="_blank" class="nav-github">
                <span class="nav-github-icon" set:html={iconBrandGithub} />
                GitHub
              </a>
            </void-button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-version">{version}</span>
          Now with Alpine/Laravel + Qwik adapters
        </div>
        <h1>Devoid<br/>of style.</h1>
        <p class="hero-sub">
          45+ Lit 3 web components with zero visual CSS.<br/>
          Theming flows through tokens. You own the style.<br/>
          Use a modern theme with clean defaults or roll your own.
        </p>
        <div class="install-pill" id="install-pill">
          <span class="install-pill-dollar">$</span>
          npm i @voidable/ui @voidable/theme
        </div>
        <div class="hero-actions">
          <void-button variant="filled" size="lg"><a href="/getting-started/installation/">Get started</a></void-button>
          <void-button variant="outline" size="lg" class="hero-outline-btn"><a href="/getting-started/introduction/">Documentation</a></void-button>
        </div>
      </div>
    </section>

    <!-- Frameworks -->
    <section class="frameworks">
      <div class="frameworks-eyebrow">One library. Every framework.</div>
      <div class="framework-list">
        <a href="/frameworks/react/" class="framework-pill">React</a>
        <a href="/frameworks/solid/" class="framework-pill">Solid</a>
        <a href="/frameworks/vue/" class="framework-pill">Vue</a>
        <a href="/frameworks/svelte/" class="framework-pill">Svelte</a>
        <a href="/frameworks/angular/" class="framework-pill">Angular</a>
        <a href="/frameworks/hotwire/" class="framework-pill">Hotwire</a>
        <a href="/frameworks/alpine/" class="framework-pill">Alpine</a>
        <a href="/frameworks/liveview/" class="framework-pill">LiveView</a>
        <a href="/frameworks/qwik/" class="framework-pill">Qwik</a>
        <a href="/frameworks/astro/" class="framework-pill">Astro</a>
        <a href="/frameworks/lit/" class="framework-pill">Lit</a>
        <a href="/frameworks/vanilla/" class="framework-pill">Vanilla</a>
      </div>
    </section>

    <!-- Feature Grid -->
    <section class="feature-section">
      <div class="feature-header">
        <div class="eyebrow">Foundation</div>
        <h2 class="feature-heading">Built on a single<br/>architectural decision.</h2>
        <p class="feature-sub">Shadow DOM solves encapsulation. Voidable solves the opposite problem: components that are deliberately transparent to their environment.</p>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-card-title">Light DOM rendering</div>
          <p class="feature-card-desc">No Shadow DOM barrier. Your CSS reaches into every component without ::part() incantations.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card-title">Token-driven theming</div>
          <p class="feature-card-desc">Three-layer token system. Override CSS custom properties; the entire library remaps.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card-title">Federation-ready</div>
          <p class="feature-card-desc">Singleton-safe customElements.define(). Same library loads once across federated modules.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card-title">Embedded-grade bundles</div>
          <p class="feature-card-desc">Pairs with Solid + UnoCSS for bundle sizes that are IoT friendly. Tree-shakes to component-level granularity.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card-title">Agent-friendly markup</div>
          <p class="feature-card-desc">Semantic void-* custom elements with reflected attributes. Stable selectors for Playwright, AI agents, screen readers.</p>
        </div>
        <div class="feature-card">
          <div class="feature-card-title">Sharp / curvy shapes</div>
          <p class="feature-card-desc">data-shape="sharp" zeros every radius globally or locally. Brand toggle without CSS rewrites.</p>
        </div>
      </div>
    </section>

    <!-- Token Showcase -->
    <section class="token-section">
      <div class="token-grid">
        <div>
          <div class="eyebrow">Theming</div>
          <h2 class="token-heading">Tokens as<br/>the only API surface.</h2>
          <p class="token-description">
            Three layers. Primitives are raw: color scales, spacing, type, radii. Semantic tokens map to roles: <code>--void-color-bg</code>, <code>--void-color-text-secondary</code>, <code>--void-color-border-strong</code>. Component CSS references only tokens. Override any layer; the whole library follows.
          </p>
          <div class="token-rows">
            <div class="token-row">
              <span class="token-swatch" style="background: #000000;"></span>
              <span class="token-name">--void-color-bg</span>
              <span class="token-value">#000000</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: #0a0a0a;"></span>
              <span class="token-name">--void-color-bg-secondary</span>
              <span class="token-value">#0a0a0a</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: #f5f5f4;"></span>
              <span class="token-name">--void-color-text</span>
              <span class="token-value">stone-100</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: rgba(255,255,255,0.14);"></span>
              <span class="token-name">--void-color-border</span>
              <span class="token-value">white / 14%</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: #22c55e;"></span>
              <span class="token-name">--void-color-success</span>
              <span class="token-value">#22c55e</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: transparent; border-color: transparent;"></span>
              <span class="token-name">--void-radius-lg</span>
              <span class="token-value">12px</span>
            </div>
            <div class="token-row">
              <span class="token-swatch" style="background: transparent; border-color: transparent;"></span>
              <span class="token-name">--void-shadow-md</span>
              <span class="token-value">white-glow</span>
            </div>
          </div>
        </div>
        <div>
          <div class="token-code-block" set:html={highlightedCss} />
        </div>
      </div>
    </section>

    <!-- Live Components -->
    <section class="components">
      <div class="components-inner">
        <div class="eyebrow">Components</div>
        <div class="components-panel">

          <div>
            <div class="component-row-label">Buttons</div>
            <div class="component-row">
              <void-button variant="filled">Default</void-button>
              <void-button variant="filled" color="success">Success</void-button>
              <void-button variant="filled" color="error">Error</void-button>
              <void-button variant="filled" color="warning">Warning</void-button>
              <void-button variant="filled" color="info">Info</void-button>
              <void-button variant="filled" color="notice">Notice</void-button>
            </div>
            <div class="component-row">
              <void-button variant="outline">Default</void-button>
              <void-button variant="outline" color="success">Success</void-button>
              <void-button variant="outline" color="error">Error</void-button>
              <void-button variant="outline" color="warning">Warning</void-button>
              <void-button variant="outline" color="info">Info</void-button>
              <void-button variant="outline" color="notice">Notice</void-button>
            </div>
          </div>

          <div>
            <div class="component-row-label">Badges</div>
            <div class="component-row">
              <void-badge color="default">Default</void-badge>
              <void-badge color="success">Success</void-badge>
              <void-badge color="warning">Warning</void-badge>
              <void-badge color="error">Error</void-badge>
              <void-badge color="info">Info</void-badge>
              <void-badge color="notice">Notice</void-badge>
              <void-badge color="highlight">Highlight</void-badge>
            </div>
            <div class="component-row">
              <void-badge variant="outline" color="default">Default</void-badge>
              <void-badge variant="outline" color="success">Success</void-badge>
              <void-badge variant="outline" color="warning">Warning</void-badge>
              <void-badge variant="outline" color="error">Error</void-badge>
              <void-badge variant="outline" color="info">Info</void-badge>
              <void-badge variant="outline" color="notice">Notice</void-badge>
              <void-badge variant="outline" color="highlight">Highlight</void-badge>
            </div>
          </div>

          <div>
            <div class="component-row-label">Form</div>
            <div class="component-row" style="align-items: flex-end; gap: var(--void-space-6); flex-wrap: wrap;">
              <void-field label="Email address">
                <void-input type="email" placeholder="you@example.com"></void-input>
              </void-field>
              <void-switch checked></void-switch>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">45+</div>
          <div class="stat-label">web components</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">10</div>
          <div class="stat-label">framework adapters</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">0</div>
          <div class="stat-label">visual CSS in core</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">12 kB</div>
          <div class="stat-label">gzipped runtime</div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <h2>Ship structure.<br/>Create style.</h2>
      <p>Read the docs, copy the install line, render a button. Ten minutes.</p>
      <div class="cta-actions">
        <void-button variant="filled" size="lg"><a href="/getting-started/introduction/">Read the docs</a></void-button>
        <void-button variant="outline" size="lg" class="hero-outline-btn"><a href="https://github.com/VoidableUI/Voidable" target="_blank">Star on GitHub</a></void-button>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <span class="footer-wordmark">voidable</span>
          <ul class="footer-links">
            <li><a href="/getting-started/introduction/">Docs</a></li>
            <li><a href="/storybook/">Storybook</a></li>
            <li><a href="https://github.com/VoidableUI/Voidable" target="_blank">GitHub</a></li>
          </ul>
        </div>
        <div class="footer-bottom">
          <span>&copy; voidable.dev &middot; MIT</span>
          <span>{version}</span>
        </div>
      </div>
    </footer>

    <script>
      import '@voidable/ui';

      const themeToggle = document.getElementById('theme-toggle')!;
      const html = document.documentElement;

      themeToggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        html.setAttribute('data-theme', current === 'dark' ? 'light' : 'dark');
      });
    </script>
  </body>
</html>
