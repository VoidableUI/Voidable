---
import '@voidable/theme';
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Voidable UI — Framework-agnostic web components built with Lit</title>
    <meta name="description" content="A framework-agnostic web component library built with Lit 3. Light DOM, CSS token theming, adapters for React, Vue, Solid, Svelte, Angular, and Hotwire." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SVG noise filter -->
    <svg width="0" height="0" style="position:absolute">
      <defs>
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
          <feColorMatrix type="saturate" values="0" />
          <feBlend in="SourceGraphic" mode="overlay" result="blend" />
          <feComposite in="blend" in2="SourceGraphic" operator="in" />
        </filter>
      </defs>
    </svg>

    <style>
      /* ── Custom Properties ── */
      :root {
        --landing-bg: #050508;
        --landing-glow: #00e5c8;
        --landing-glow-dim: rgba(0, 229, 200, 0.15);
        --landing-warm: #f5a623;
        --landing-text: #e8e8ec;
        --landing-text-dim: #7a7a85;
        --landing-surface: rgba(255, 255, 255, 0.04);
        --landing-border: rgba(255, 255, 255, 0.08);
      }

      /* ── Reset ── */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
      }

      /* ── Base ── */
      html {
        font-family: var(--void-font-sans);
        color: var(--landing-text);
        background: var(--landing-bg);
        scroll-behavior: smooth;
      }

      body {
        min-height: 100dvh;
        line-height: 1.6;
        overflow-x: hidden;
        position: relative;
      }

      /* Noise texture overlay */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
        background-size: 200px 200px;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Container ── */
      .container {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 2rem;
      }

      /* ── Keyframes ── */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes float {
        0%,  100% { transform: translate(0, 0) rotate(0deg); }
        50%        { transform: translate(10px, -10px) rotate(3deg); }
      }

      @keyframes pulse-glow {
        0%,  100% { opacity: 0.3; }
        50%        { opacity: 0.6; }
      }

      /* ── Hero ── */
      .hero {
        position: relative;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 6rem 2rem 5rem;
        overflow: hidden;
      }

      /* Dot grid */
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
        background-size: 32px 32px;
        pointer-events: none;
        mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
        -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
      }

      .hero-inner {
        position: relative;
        z-index: 2;
        max-width: 52rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.75rem;
        animation: fadeInUp 0.8s ease both;
      }

      /* Radial glow behind heading */
      .hero-glow {
        position: absolute;
        inset: -10% -20%;
        background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(0, 229, 200, 0.18) 0%, transparent 70%);
        pointer-events: none;
        animation: pulse-glow 4s ease-in-out infinite;
        z-index: 1;
      }

      .hero h1 {
        font-family: var(--void-font-sans);
        font-weight: 700;
        font-size: clamp(3rem, 8vw, 6rem);
        letter-spacing: -0.04em;
        line-height: 1;
        position: relative;
        z-index: 2;
      }

      .hero h1 .glow-text {
        color: var(--landing-glow);
      }

      .hero .tagline {
        font-family: var(--void-font-sans);
        font-weight: 400;
        font-size: clamp(1rem, 2.2vw, 1.2rem);
        color: var(--landing-text-dim);
        max-width: 36rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .hero-actions a {
        display: block;
      }

      .install-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.125rem;
        border: 1px solid var(--landing-border);
        border-radius: 999px;
        background: var(--landing-surface);
        font-family: var(--void-font-mono);
        font-size: 0.8rem;
        color: var(--landing-text-dim);
        letter-spacing: 0.01em;
        transition: border-color 0.2s, color 0.2s;
      }

      .install-pill:hover {
        border-color: var(--landing-glow-dim);
        color: var(--landing-text);
      }

      .install-pill::before {
        content: '$';
        color: var(--landing-glow);
        font-weight: 500;
      }

      /* Decorative circles */
      .deco-circle {
        position: absolute;
        border-radius: 50%;
        border: 1px solid var(--landing-glow);
        pointer-events: none;
        z-index: 1;
      }

      .deco-circle-1 {
        width: 480px;
        height: 480px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        opacity: 0.06;
        animation: float 15s ease-in-out infinite;
      }

      .deco-circle-2 {
        width: 700px;
        height: 700px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        opacity: 0.04;
        animation: float 20s ease-in-out infinite reverse;
      }

      .deco-circle-3 {
        width: 240px;
        height: 240px;
        top: 12%;
        right: 8%;
        opacity: 0.05;
        animation: float 25s ease-in-out infinite;
      }

      /* ── Features ── */
      .features {
        padding: 5rem 0;
        animation: fadeInUp 0.8s 0.15s ease both;
      }

      .section-title {
        font-family: var(--void-font-sans);
        font-weight: 700;
        font-size: clamp(1.6rem, 3.5vw, 2.25rem);
        letter-spacing: -0.03em;
        text-align: center;
        margin-bottom: 3rem;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }

      @media (max-width: 640px) {
        .features-grid {
          grid-template-columns: 1fr;
        }
      }

      .feature-card {
        padding: 1.75rem;
        background: var(--landing-surface);
        border: 1px solid var(--landing-border);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
        animation: fadeInUp 0.7s ease both;
      }

      .feature-card:nth-child(1) { animation-delay: 0.05s; }
      .feature-card:nth-child(2) { animation-delay: 0.15s; }
      .feature-card:nth-child(3) { animation-delay: 0.25s; }
      .feature-card:nth-child(4) { animation-delay: 0.35s; }

      .feature-card:hover {
        border-color: var(--landing-glow-dim);
        box-shadow: 0 0 32px rgba(0, 229, 200, 0.08);
        transform: translateY(-2px);
      }

      .feature-icon {
        font-size: 1.4rem;
        margin-bottom: 0.875rem;
        color: var(--landing-glow);
        line-height: 1;
      }

      .feature-title {
        font-family: var(--void-font-sans);
        font-weight: 600;
        font-size: 1.05rem;
        margin-bottom: 0.5rem;
        letter-spacing: -0.01em;
      }

      .feature-desc {
        font-family: var(--void-font-sans);
        font-size: 0.9rem;
        color: var(--landing-text-dim);
        line-height: 1.65;
      }

      /* ── Showcase ── */
      .showcase {
        padding: 5rem 0;
        animation: fadeInUp 0.8s 0.3s ease both;
      }

      .showcase-panel {
        background: var(--landing-surface);
        border: 1px solid var(--landing-border);
        border-left: 3px solid var(--landing-glow);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      .showcase-block {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
      }

      .showcase-label {
        font-family: var(--void-font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--landing-text-dim);
      }

      .showcase-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.625rem;
        align-items: center;
      }

      /* ── Frameworks ── */
      .frameworks {
        padding: 5rem 0;
        text-align: center;
        animation: fadeInUp 0.8s 0.45s ease both;
      }

      .frameworks .subtitle {
        font-family: var(--void-font-sans);
        font-size: 1rem;
        color: var(--landing-text-dim);
        margin-top: 0.5rem;
        margin-bottom: 2.5rem;
      }

      .framework-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .framework-pill {
        padding: 0.5rem 1.25rem;
        background: var(--landing-surface);
        border: 1px solid var(--landing-border);
        border-radius: 999px;
        font-family: var(--void-font-mono);
        font-size: 0.85rem;
        color: var(--landing-text-dim);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
        cursor: default;
      }

      .framework-pill:hover {
        border-color: var(--landing-glow);
        color: var(--landing-text);
        box-shadow: 0 0 16px rgba(0, 229, 200, 0.1);
      }

      /* ── Divider ── */
      .section-divider {
        width: 100%;
        height: 1px;
        background: var(--landing-border);
        margin: 0;
      }

      /* ── Footer ── */
      .footer {
        padding: 2.5rem 2rem 3rem;
        border-top: 1px solid var(--landing-border);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
      }

      .footer-links {
        display: flex;
        gap: 2.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .footer-links a {
        font-family: var(--void-font-sans);
        font-size: 0.875rem;
        color: var(--landing-text-dim);
        transition: color 0.2s;
      }

      .footer-links a:hover {
        color: var(--landing-text);
      }

      .footer-copy {
        font-family: var(--void-font-mono);
        font-size: 0.75rem;
        color: var(--landing-text-dim);
        opacity: 0.6;
        letter-spacing: 0.02em;
      }
    </style>
  </head>
  <body>

    <!-- Hero -->
    <section class="hero">
      <div class="deco-circle deco-circle-1"></div>
      <div class="deco-circle deco-circle-2"></div>
      <div class="deco-circle deco-circle-3"></div>

      <div class="hero-inner">
        <div class="hero-glow"></div>
        <h1>Voidable <span class="glow-text">UI</span></h1>
        <p class="tagline">Framework-agnostic web components built with Lit. Light DOM, CSS token theming, and adapters for every major framework.</p>
        <div class="hero-actions">
          <a href="/getting-started/installation/">
            <void-button variant="filled">Get Started</void-button>
          </a>
          <a href="/storybook/" target="_blank">
            <void-button variant="outline">Storybook</void-button>
          </a>
        </div>
        <span class="install-pill">npm install @voidable/ui @voidable/theme</span>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <h2 class="section-title">Why Voidable?</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">◆</div>
            <div class="feature-title">45+ Components</div>
            <p class="feature-desc">Production-ready UI primitives for layout, forms, data display, feedback, and navigation — all in one cohesive system.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">○</div>
            <div class="feature-title">Light DOM</div>
            <p class="feature-desc">No Shadow DOM barriers. Your CSS has full access to every component's internals — style freely without workarounds.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">⬡</div>
            <div class="feature-title">Framework Adapters</div>
            <p class="feature-desc">First-class support for React, Vue, Solid, Svelte, Angular, and Hotwire. Drop in anywhere without friction.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">◐</div>
            <div class="feature-title">Themeable by Design</div>
            <p class="feature-desc">CSS custom property tokens with built-in dark and light modes. Override any token — adapt the entire system to your brand.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Component Showcase -->
    <section class="showcase">
      <div class="container">
        <h2 class="section-title">See it in action</h2>
        <div class="showcase-panel">

          <div class="showcase-block">
            <span class="showcase-label">Buttons</span>
            <div class="showcase-row">
              <void-button variant="filled">Filled</void-button>
              <void-button variant="outline">Outline</void-button>
              <void-button variant="filled" color="success">Success</void-button>
              <void-button variant="filled" color="error">Error</void-button>
            </div>
          </div>

          <div class="showcase-block">
            <span class="showcase-label">Badges</span>
            <div class="showcase-row">
              <void-badge color="default">Default</void-badge>
              <void-badge color="success">Success</void-badge>
              <void-badge color="warning">Warning</void-badge>
              <void-badge color="error">Error</void-badge>
              <void-badge color="info">Info</void-badge>
            </div>
          </div>

          <div class="showcase-block">
            <span class="showcase-label">Form field</span>
            <void-field label="Email address">
              <void-input type="email" placeholder="you@example.com"></void-input>
            </void-field>
          </div>

          <div class="showcase-block">
            <span class="showcase-label">Toggle</span>
            <div class="showcase-row">
              <void-switch checked></void-switch>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Frameworks -->
    <section class="frameworks">
      <div class="container">
        <h2 class="section-title">Universal by design</h2>
        <p class="subtitle">Native custom element support plus dedicated adapters with theme utilities.</p>
        <div class="framework-pills">
          <span class="framework-pill">React</span>
          <span class="framework-pill">Vue</span>
          <span class="framework-pill">Solid</span>
          <span class="framework-pill">Svelte</span>
          <span class="framework-pill">Angular</span>
          <span class="framework-pill">Hotwire</span>
          <span class="framework-pill">Vanilla JS</span>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-links">
        <a href="/getting-started/introduction/">Docs</a>
        <a href="/storybook/" target="_blank">Storybook</a>
        <a href="https://github.com/VoidableUI/Voidable" target="_blank">GitHub</a>
      </div>
      <span class="footer-copy">Built with Lit · Open Source</span>
    </footer>

    <script>
      import '@voidable/ui';
    </script>
  </body>
</html>
