---
import '@voidable/theme';
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Voidable UI — Framework-agnostic web components built with Lit</title>
    <meta name="description" content="A framework-agnostic web component library built with Lit 3. Light DOM, CSS token theming, adapters for React, Vue, Solid, Svelte, Angular, and Hotwire." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
      }

      html {
        font-family: var(--void-font-sans);
        color: var(--void-color-text);
        background: #000000;
      }

      body {
        min-height: 100dvh;
        line-height: 1.6;
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        max-width: 64rem;
        margin: 0 auto;
        padding: 0 2rem;
      }

      /* ── Nav ── */
      .nav {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 1.25rem 0;
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-wordmark {
        font-family: var(--void-font-mono);
        font-weight: 600;
        font-size: 0.875rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--void-color-text);
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
      }

      .nav-links a {
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--void-color-text-secondary);
        transition: color 150ms;
      }

      .nav-links a:hover {
        color: var(--void-color-text);
      }

      /* ── Hero ── */
      .hero {
        padding: 8rem 0 6rem;
      }

      .hero-inner {
        max-width: 44rem;
      }

      .hero h1 {
        font-family: var(--void-font-sans);
        font-weight: 600;
        font-size: clamp(2rem, 5vw, 3.5rem);
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--void-color-text);
        margin-bottom: 1.25rem;
      }

      .hero-sub {
        font-size: 1rem;
        color: var(--void-color-text-secondary);
        margin-bottom: 2rem;
      }

      .install-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        font-family: var(--void-font-mono);
        font-size: 0.8rem;
        color: var(--void-color-text-secondary);
        margin-bottom: 2rem;
        transition: color 150ms;
      }

      .install-pill:hover {
        color: var(--void-color-text);
      }

      .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .hero-actions a {
        display: block;
      }

      /* ── Code example ── */
      .code-section {
        padding: 6rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }

      .code-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      }

      @media (max-width: 720px) {
        .code-grid {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }

      .code-left h2 {
        font-weight: 600;
        font-size: 1.4rem;
        letter-spacing: -0.01em;
        color: var(--void-color-text);
        margin-bottom: 0.875rem;
      }

      .code-left p {
        font-size: 0.9rem;
        color: var(--void-color-text-secondary);
        line-height: 1.7;
      }

      .code-block {
        background: #0a0a0a;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 1.5rem;
        overflow-x: auto;
      }

      .code-block pre {
        margin: 0;
        font-family: var(--void-font-mono);
        font-size: 0.8rem;
        line-height: 1.7;
        color: var(--void-color-text);
        white-space: pre;
      }

      /* ── Features ── */
      .features {
        padding: 6rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }

      .section-label {
        font-family: var(--void-font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--void-color-text-secondary);
        margin-bottom: 3rem;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem 3rem;
      }

      @media (max-width: 720px) {
        .features-grid {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }

      @media (min-width: 480px) and (max-width: 720px) {
        .features-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      .feature-title {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--void-color-text);
        margin-bottom: 0.375rem;
      }

      .feature-desc {
        font-size: 0.875rem;
        color: var(--void-color-text-secondary);
        line-height: 1.6;
      }

      /* ── Components ── */
      .components {
        padding: 6rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }

      .components-panel {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .component-row-label {
        font-family: var(--void-font-mono);
        font-size: 0.65rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--void-color-text-secondary);
        margin-bottom: 0.75rem;
      }

      .component-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
      }

      /* ── Frameworks ── */
      .frameworks {
        padding: 6rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        text-align: center;
      }

      .frameworks .section-label {
        margin-bottom: 1.5rem;
      }

      .framework-list {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--void-color-text-secondary);
        letter-spacing: 0.01em;
      }

      /* ── Footer ── */
      .footer {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem 0;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer-wordmark {
        font-family: var(--void-font-mono);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--void-color-text-secondary);
      }

      .footer-links {
        display: flex;
        gap: 1.75rem;
        list-style: none;
      }

      .footer-links a {
        font-size: 0.8rem;
        color: var(--void-color-text-secondary);
        transition: color 150ms;
      }

      .footer-links a:hover {
        color: var(--void-color-text);
      }
    </style>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav">
      <div class="container">
        <div class="nav-inner">
          <span class="nav-wordmark">Voidable</span>
          <ul class="nav-links">
            <li><a href="/getting-started/introduction/">Docs</a></li>
            <li><a href="/storybook/">Storybook</a></li>
            <li><a href="https://github.com/VoidableUI/Voidable" target="_blank">GitHub</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <h1>The component library that stays out of your way.</h1>
          <p class="hero-sub">45+ Lit web components. Light DOM. CSS tokens. Framework adapters.</p>
          <div class="install-pill">npm install @voidable/ui @voidable/theme</div>
          <div class="hero-actions">
            <a href="/getting-started/installation/">
              <void-button variant="filled">Get Started</void-button>
            </a>
            <a href="/getting-started/introduction/">
              <void-button variant="outline">Documentation</void-button>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Code example -->
    <section class="code-section">
      <div class="container">
        <div class="code-grid">
          <div class="code-left">
            <h2>Drop in anywhere</h2>
            <p>Light DOM means no Shadow DOM barriers between your styles and the components. Works with any framework — or none at all. Import once, use everywhere.</p>
          </div>
          <div class="code-block">
            <pre>&lt;script type="module"&gt;
  import '@voidable/ui'
&lt;/script&gt;

&lt;void-button variant="filled"&gt;Save&lt;/void-button&gt;
&lt;void-input placeholder="Search..."&gt;&lt;/void-input&gt;
&lt;void-switch checked&gt;&lt;/void-switch&gt;</pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <p class="section-label">Features</p>
        <div class="features-grid">
          <div class="feature">
            <div class="feature-title">Light DOM</div>
            <p class="feature-desc">No Shadow DOM. Your styles reach every element.</p>
          </div>
          <div class="feature">
            <div class="feature-title">CSS Token Theming</div>
            <p class="feature-desc">Dark and light modes via data-theme. Override any token.</p>
          </div>
          <div class="feature">
            <div class="feature-title">Framework Adapters</div>
            <p class="feature-desc">React, Vue, Solid, Svelte, Angular, Hotwire.</p>
          </div>
          <div class="feature">
            <div class="feature-title">45+ Components</div>
            <p class="feature-desc">Forms, layout, feedback, navigation, data display.</p>
          </div>
          <div class="feature">
            <div class="feature-title">Accessible</div>
            <p class="feature-desc">ARIA attributes, keyboard navigation, screen readers.</p>
          </div>
          <div class="feature">
            <div class="feature-title">Zero Runtime CSS</div>
            <p class="feature-desc">All styling through @voidable/theme. No CSS-in-JS.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Live components -->
    <section class="components">
      <div class="container">
        <p class="section-label">Components</p>
        <div class="components-panel">

          <div>
            <div class="component-row-label">Buttons</div>
            <div class="component-row">
              <void-button variant="filled">Filled</void-button>
              <void-button variant="outline">Outline</void-button>
              <void-button variant="filled" color="success">Success</void-button>
              <void-button variant="filled" color="error">Error</void-button>
            </div>
          </div>

          <div>
            <div class="component-row-label">Badges</div>
            <div class="component-row">
              <void-badge color="default">Default</void-badge>
              <void-badge color="success">Success</void-badge>
              <void-badge color="warning">Warning</void-badge>
              <void-badge color="error">Error</void-badge>
              <void-badge color="info">Info</void-badge>
            </div>
          </div>

          <div>
            <div class="component-row-label">Form</div>
            <div class="component-row" style="align-items: flex-end; gap: 1.5rem; flex-wrap: wrap;">
              <void-field label="Email address">
                <void-input type="email" placeholder="you@example.com"></void-input>
              </void-field>
              <void-switch checked></void-switch>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Frameworks -->
    <section class="frameworks">
      <div class="container">
        <p class="section-label">Frameworks</p>
        <p class="framework-list">React · Vue · Solid · Svelte · Angular · Hotwire · Vanilla JS</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-inner">
          <span class="footer-wordmark">Voidable</span>
          <ul class="footer-links">
            <li><a href="/getting-started/introduction/">Docs</a></li>
            <li><a href="/storybook/">Storybook</a></li>
            <li><a href="https://github.com/VoidableUI/Voidable" target="_blank">GitHub</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <script>
      import '@voidable/ui';
    </script>
  </body>
</html>
