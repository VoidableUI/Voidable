<%% content_for :title, "Editing <%= human_name.downcase %>" %>

<h1>Editing <%= human_name.downcase %></h1>

<%%= render "form", <%= singular_table_name %>: @<%= singular_table_name %> %>

<void-button tag="a" href="<%%= url_for(<%= model_resource_name(prefix: "@") %>) %>" variant="ghost">Show</void-button>
<void-button tag="a" href="<%%= <%= index_helper(type: :path) %> %>" variant="ghost">Back to <%= human_name.pluralize.downcase %></void-button>
