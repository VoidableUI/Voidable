<div id="<%= dom_id order %>">
  <div>
    <strong>Customer name:</strong>
    <%= order.customer_name %>
  </div>

  <div>
    <strong>Total:</strong>
    <%= order.total %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= order.status %>
  </div>

  <div>
    <strong>Shipped:</strong>
    <%= order.shipped %>
  </div>

  <div>
    <strong>Notes:</strong>
    <%= order.notes %>
  </div>

</div>
