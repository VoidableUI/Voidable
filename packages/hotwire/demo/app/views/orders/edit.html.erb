<% content_for :title, "Editing order" %>

<div class="page-header">
  <p class="page-breadcrumb">
    <%= link_to "Orders", orders_path %> / <%= @order.customer_name %> / Edit
  </p>
  <h1 class="page-title">Edit order</h1>
</div>

<%= render "form", order: @order %>

<div class="danger-zone">
  <p class="detail-section-label">Danger zone</p>
  <void-button variant="outline" color="error" size="sm" onclick="document.getElementById('delete-dialog').open = true">Delete this order</void-button>
</div>

<void-dialog id="delete-dialog" heading="Delete order" size="sm">
  <p class="danger-zone-description">
    Are you sure you want to delete <strong><%= @order.customer_name %></strong>? This action cannot be undone.
  </p>
  <div class="action-bar">
    <void-button variant="ghost" size="sm" onclick="document.getElementById('delete-dialog').open = false">Cancel</void-button>
    <void-button color="error" size="sm"><a href="<%= url_for(@order) %>" data-turbo-method="delete">Delete</a></void-button>
  </div>
</void-dialog>
