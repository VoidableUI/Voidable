<% if resource.errors.any? %>
  <void-alert color="error" data-turbo-temporary>
    <strong><%= pluralize(resource.errors.count, "error") %> prohibited this operation:</strong>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </void-alert>
<% end %>
