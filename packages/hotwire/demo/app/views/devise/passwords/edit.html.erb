<void-card>
  <h2>Change your password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.hidden_field :reset_password_token %>

    <void-field label="New password">
      <void-input type="password" name="<%= resource_name %>[password]" autofocus autocomplete="new-password" minlength="<%= @minimum_password_length %>"></void-input>
    </void-field>

    <void-field label="Confirm new password">
      <void-input type="password" name="<%= resource_name %>[password_confirmation]" autocomplete="new-password"></void-input>
    </void-field>

    <div>
      <void-button type="submit" color="success">Change my password</void-button>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</void-card>
