<% content_for :title, @product.name.to_s %>
<% content_for :header_actions do %>
  <void-dropdown-menu position="bottom-end">
    <void-button color="caution" variant="outline" size="sm">Actions</void-button>
    <void-dropdown-menu-item><a href="<%= edit_product_path(@product) %>">Edit</a></void-dropdown-menu-item>
    <hr>
    <void-dropdown-menu-item destructive onclick="document.getElementById('delete-dialog').open = true">Delete</void-dropdown-menu-item>
  </void-dropdown-menu>
<% end %>

<% if notice.present? %>
  <void-alert color="success" dismissible style="margin-bottom: var(--void-space-4);"><%= notice %></void-alert>
<% end %>

<void-card>
  <div style="padding: var(--void-space-5);">
    <p style="font-family: var(--void-font-sans); font-size: var(--void-text-xs); font-weight: var(--void-weight-semibold); color: var(--void-color-text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 var(--void-space-3) 0;">Details</p>
    <dl style="display: grid; grid-template-columns: 10rem 1fr; gap: var(--void-space-3) var(--void-space-4); margin: 0;">
      <dt style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text-secondary); margin: 0; padding-top: 2px;">Name</dt>
      <dd style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text); margin: 0;"><%= @product.name %></dd>
      <dt style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text-secondary); margin: 0; padding-top: 2px;">Description</dt>
      <dd style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text); margin: 0;"><%= @product.description %></dd>
      <dt style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text-secondary); margin: 0; padding-top: 2px;">Price</dt>
      <dd style="font-family: var(--void-font-mono); font-size: var(--void-text-sm); color: var(--void-color-text); margin: 0;"><%= @product.price %></dd>
      <dt style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text-secondary); margin: 0; padding-top: 2px;">Active</dt>
      <dd style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text); margin: 0;">
        <void-badge color="<%= @product.active ? 'success' : 'default' %>" variant="outline"><%= @product.active ? 'Yes' : 'No' %></void-badge>
      </dd>
    </dl>
  </div>
</void-card>

<div style="margin-top: var(--void-space-4);">
  <void-button variant="ghost" size="sm"><a href="<%= products_path %>">&#x2190; Back to products</a></void-button>
</div>

<void-dialog id="delete-dialog" heading="Delete product" size="sm">
  <p style="font-family: var(--void-font-sans); font-size: var(--void-text-sm); color: var(--void-color-text); margin: 0 0 var(--void-space-4) 0;">
    Are you sure you want to delete this product? This action cannot be undone.
  </p>
  <div style="display: flex; gap: var(--void-space-2); justify-content: flex-end;">
    <void-button variant="ghost" size="sm" onclick="document.getElementById('delete-dialog').open = false">Cancel</void-button>
    <void-button color="error" size="sm"><a href="<%= url_for(@product) %>" data-turbo-method="delete">Delete</a></void-button>
  </div>
</void-dialog>
